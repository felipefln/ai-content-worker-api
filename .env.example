# Ambiente da aplicação (development, production, test)
NODE_ENV=development
# Porta em que a API Fastify sobe
PORT=3000

# String de conexão do PostgreSQL usada pelo Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/ai_content_worker?schema=public

# URL de conexão do Redis usada pelo BullMQ (fila e worker)
REDIS_URL=redis://localhost:6379

# Endpoint do storage S3-compatível (Minio local ou AWS S3 real)
S3_ENDPOINT=http://localhost:9000
# Região do bucket (obrigatório pelo AWS SDK mesmo usando Minio)
S3_REGION=us-east-1
# Nome do bucket onde os arquivos gerados são salvos
S3_BUCKET=ai-content
# Credenciais de acesso ao S3/Minio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Minio exige path-style addressing (http://host/bucket/key); AWS S3 real usa virtual-hosted style por padrão
S3_FORCE_PATH_STYLE=true

# Tempo (ms) que a simulação de IA espera antes de responder
AI_SIMULATION_DELAY_MS=5000
# Probabilidade (0 a 1) de a simulação de IA falhar de propósito, pra testar o retry do worker
AI_SIMULATION_FAILURE_RATE=0.2
